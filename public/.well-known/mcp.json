  "tools": [
    {
      "name": "book_group_cruise",
      "description": "Redirect to WhatsApp/Telegram/Zalo with a pre-filled group-tour booking message. Query: type, lang, channel, date, guests.",
      "endpoint": "https://seatrips-nhatrang.com/api/book?type=group&lang=ru&channel=whatsapp",
      "method": "GET",
      "inputSchema": {
        "type": "object",
        "properties": {
          "lang": {
            "type": "string",
            "enum": [
              "ru",
              "en",
              "ko",
              "kk"
            ],
            "default": "ru"
          },
          "channel": {
            "type": "string",
            "enum": [
              "whatsapp",
              "telegram",
              "zalo"
            ],
            "default": "whatsapp"
          },
          "date": {
            "type": "string"
          },
          "guests": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    {
      "name": "book_private_cruise",
      "description": "Redirect with pre-filled private charter message.",
      "endpoint": "https://seatrips-nhatrang.com/api/book?type=individual&lang=ru&channel=whatsapp",
      "method": "GET",
      "inputSchema": {
        "type": "object",
        "properties": {
          "lang": {
            "type": "string",
            "enum": [
              "ru",
              "en",
              "ko",
              "kk"
            ]
          },
          "channel": {
            "type": "string",
            "enum": [
              "whatsapp",
              "telegram",
              "zalo"
            ]
          },
          "date": {
            "type": "string"
          },
          "guests": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    {
      "name": "book_vip_cruise",
      "description": "Redirect with pre-filled VIP cruise message.",
      "endpoint": "https://seatrips-nhatrang.com/api/book?type=vip&lang=ru&channel=whatsapp",
      "method": "GET",
      "inputSchema": {
        "type": "object",
        "properties": {
          "lang": {
            "type": "string",
            "enum": [
              "ru",
              "en",
              "ko",
              "kk"
            ]
          },
          "channel": {
            "type": "string",
            "enum": [
              "whatsapp",
              "telegram",
              "zalo"
            ]
          }
        }
      }
    },
    {
      "name": "contact_telegram",
      "description": "Open Telegram chat.",
      "endpoint": "https://seatrips-nhatrang.com/api/book?type=group&lang=ru&channel=telegram",
      "method": "GET"
    }
